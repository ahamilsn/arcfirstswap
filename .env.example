# WalletConnect Project ID - Get from https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Circle Kit Key - Prefer keeping this server-side for quotes and swaps
CIRCLE_API_KEY=your_kit_key_here

# Optional legacy browser-side fallback. Leave empty when using CIRCLE_API_KEY.
NEXT_PUBLIC_KIT_KEY=
